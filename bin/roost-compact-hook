#!/bin/sh
# PreCompact hook — two jobs, both keyed off the trigger field:
#
# 1. trigger="auto" + a directive declared at spawn:
#    return {"decision":"block"} to halt the directive-less auto-compact,
#    then inject `/compact <directive>` into our own tmux pane (backgrounded
#    with a small sleep) so the manual /compact runs with our
#    custom_instructions. The injected manual compact re-fires PreCompact with
#    trigger="manual" — we pass through that round without blocking.
#
# 2. trigger="manual" OR no directive: pass through. Still send SIGUSR1 to
#    the MCP so its replay-dedupe cache clears (next chathistory backfill
#    delivers messages compacted out of the agent's context).
#
# Wired by bin/roost at spawn time via roost-settings.json. Never exits
# non-zero on its happy path — a hook failure must not block compaction
# (the {"decision":"block"} we DO emit in case 1 is the explicit signal).
#
# Issue #368, v3 design — see docs/LEARNINGS.md Finding J.
set -u

log() { echo "roost-compact-hook: $*" >&2; }

input="$(cat)"

# Extract trigger ("auto"|"manual"). Fallback parser is grep+sed so we don't
# require jq on the operator's box. Defaults to "manual" on parse failure
# (the safer side: we pass through rather than blocking).
trigger="$(printf '%s' "$input" \
  | grep -o '"trigger"[[:space:]]*:[[:space:]]*"[^"]*"' \
  | head -1 \
  | sed 's/.*"trigger"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')"
[ -z "$trigger" ] && trigger="manual"

signal_mcp() {
  if [ -z "${ROOST_DATA_DIR:-}" ]; then
    log "ROOST_DATA_DIR not set; skipping SIGUSR1"
    return 0
  fi
  pid_file="${ROOST_DATA_DIR}/mcp.pid"
  if [ ! -f "$pid_file" ]; then
    log "$pid_file not found; skipping SIGUSR1"
    return 0
  fi
  pid="$(cat "$pid_file")"
  case "$pid" in
    ''|*[!0-9]*)
      log "malformed pid in $pid_file: '$pid'; skipping SIGUSR1"
      return 0 ;;
  esac
  if kill -USR1 "$pid" 2>/dev/null; then
    log "sent SIGUSR1 to MCP pid $pid"
  else
    log "kill -USR1 $pid failed (no such process?)"
  fi
}

# Auto-trigger path requires (a) a directive on disk and (b) ROOST_IRC_NICK
# so we know which tmux pane to inject into. Missing either → pass through.
directive_file="${ROOST_DATA_DIR:-}/compact-directive.txt"
nick="${ROOST_IRC_NICK:-}"

if [ "$trigger" = "auto" ] && [ -n "$nick" ] && [ -s "$directive_file" ]; then
  directive="$(cat "$directive_file")"
  # session_name written by `bin/roost` at spawn — honors `-s/--session NAME`
  # override. Fall back to the default convention if absent (hook tests
  # that don't run through `bin/roost spawn`).
  session_file="${ROOST_DATA_DIR}/session-name.txt"
  if [ -s "$session_file" ]; then
    session_name="$(cat "$session_file")"
  else
    session_name="roost-${nick}"
  fi
  if command -v tmux >/dev/null 2>&1 && tmux has-session -t "$session_name" 2>/dev/null; then
    # Background subshell: claude code reads our {"decision":"block"} on stdout
    # and unwinds its own auto-compact state machine; we want our send-keys to
    # land after that settles, not race it. 150ms is empirically clean from
    # the auto-trigger smoke (issue #368). Buffer name uses $$ (this hook
    # process's pid — distinct per invocation; a subshell inherits its
    # parent's $$ in POSIX sh) to avoid collisions across concurrent compacts.
    # The load-buffer / paste-buffer -p / send-keys Enter / delete-buffer
    # sequence mirrors `cmd_send` in bin/roost — keep them in sync if either
    # grows e.g. better multi-line handling.
    (
      sleep 0.15
      buf="roost-compact-${nick}-$$"
      printf '/compact %s' "$directive" | tmux load-buffer -b "$buf" -
      tmux paste-buffer -t "$session_name" -b "$buf" -p
      tmux send-keys -t "$session_name" Enter
      tmux delete-buffer -b "$buf" 2>/dev/null || true
    ) &
    log "auto-trigger intercepted; queued /compact <directive> for $session_name (directive bytes=$(printf '%s' "$directive" | wc -c | tr -d ' '))"
    printf '%s\n' '{"decision":"block","reason":"roost: redirecting auto-compact to manual /compact with custom_instructions (issue #368)"}'
    exit 0
  fi
  log "auto-trigger with directive present but tmux session $session_name not found; falling through"
fi

# Pass-through path (manual, or auto-without-directive, or no-tmux fallback):
# clear the MCP's replay dedupe so post-compact chathistory backfill re-delivers
# messages the compactor dropped. No stdout = no hook decision; claude code
# proceeds with its compaction.
signal_mcp
exit 0
