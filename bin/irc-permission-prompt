#!/usr/bin/env python3
"""
roost — PreToolUse hook that surfaces permission prompts via IRC DM.

Reads PreToolUse JSON from stdin, posts a DM to a configured IRC user
asking for y/n approval, and emits hookSpecificOutput with
permissionDecision = allow|deny|ask.

Use case: roost workers running on non-Opus models can't use auto mode
and would otherwise trip the terminal prompt for every tool call. With
this hook installed, the prompt instead lands in IRC where the operator
can approve from anywhere. Timeout / unrecognized reply → "ask" so the
terminal prompt is still the safety net.

Configuration (env, all optional):
  ROOST_PERM_HOST       IRC server         (default: 127.0.0.1)
  ROOST_PERM_PORT       IRC port           (default: 6667)
  ROOST_PERM_TARGET     Nick to DM         (default: alex2)
  ROOST_PERM_TIMEOUT    Reply timeout sec  (default: 30)
  ROOST_IRC_NICK        Worker nick (set by bin/roost spawn)

Pure stdlib — runs anywhere Python 3.9+ is available.
"""
import json
import os
import select
import socket
import sys
import time

HOST = os.environ.get("ROOST_PERM_HOST", "127.0.0.1")
PORT = int(os.environ.get("ROOST_PERM_PORT", "6667"))
TARGET = os.environ.get("ROOST_PERM_TARGET", "alex2")
TIMEOUT = float(os.environ.get("ROOST_PERM_TIMEOUT", "30"))
WORKER = os.environ.get("ROOST_IRC_NICK", "unknown")
DEBUG_LOG = os.environ.get("ROOST_PERM_DEBUG_LOG", "/tmp/roost-perm-hook.log")


def dlog(msg: str) -> None:
    if not DEBUG_LOG:
        return
    try:
        with open(DEBUG_LOG, "a") as f:
            f.write(f"[{time.strftime('%H:%M:%S')} pid={os.getpid()}] {msg}\n")
    except OSError:
        pass

# Tools that must NOT be intercepted, otherwise the worker can't talk on
# IRC (and we'd recurse — the hook's own DM would itself be a tool call).
PASSTHROUGH_PREFIXES = ("mcp__roost-irc__",)


def emit(decision: str, reason: str) -> None:
    json.dump(
        {
            "hookSpecificOutput": {
                "hookEventName": "PreToolUse",
                "permissionDecision": decision,
                "permissionDecisionReason": reason,
            }
        },
        sys.stdout,
    )
    sys.stdout.write("\n")
    sys.exit(0)


def summarize(tool_name: str, tool_input: dict) -> str:
    if tool_name in ("Read", "Write", "Edit", "NotebookEdit"):
        return f"{tool_name} {tool_input.get('file_path', '?')}"
    if tool_name == "Bash":
        cmd = tool_input.get("command", "")
        if len(cmd) > 240:
            cmd = cmd[:237] + "..."
        return f"Bash: {cmd}"
    if tool_name == "Grep":
        pat = tool_input.get("pattern", "?")
        path = tool_input.get("path", "")
        return f"Grep {pat!r}{(' in ' + path) if path else ''}"
    blob = json.dumps(tool_input, separators=(",", ":"))
    if len(blob) > 240:
        blob = blob[:237] + "..."
    return f"{tool_name} {blob}"


def ask_irc(question: str):
    """Connect to IRC, DM the question to TARGET, return their reply or None."""
    nick = f"permbot-{WORKER}-{os.getpid()}"[:30]
    dlog(f"connect {HOST}:{PORT} as nick={nick} target={TARGET} timeout={TIMEOUT}")
    try:
        sock = socket.create_connection((HOST, PORT), timeout=5)
    except OSError as e:
        sys.stderr.write(f"perm-hook: connect {HOST}:{PORT} failed: {e}\n")
        dlog(f"CONNECT FAIL: {e}")
        return None

    sock.setblocking(False)
    recv_buf = b""

    def send(line: str) -> None:
        dlog(f"-> {line}")
        sock.sendall((line + "\r\n").encode("utf-8"))

    def read_lines(deadline: float):
        """Yield decoded lines as they arrive; returns when deadline elapses or EOF."""
        nonlocal recv_buf
        while True:
            remaining = deadline - time.time()
            if remaining <= 0:
                return
            ready, _, _ = select.select([sock], [], [], min(remaining, 1.0))
            if not ready:
                continue
            try:
                chunk = sock.recv(4096)
            except (BlockingIOError, InterruptedError):
                continue
            except OSError as e:
                dlog(f"recv OSError: {e}")
                return
            if not chunk:
                dlog("EOF on socket")
                return
            recv_buf += chunk
            while b"\r\n" in recv_buf:
                line_b, recv_buf = recv_buf.split(b"\r\n", 1)
                yield line_b.decode("utf-8", errors="replace")

    try:
        send(f"NICK {nick}")
        send(f"USER {nick} 0 * :roost-perm-bot")

        registered = False
        for line in read_lines(time.time() + 5):
            dlog(f"<- {line}")
            if line.startswith("PING "):
                send("PONG " + line[5:])
                continue
            parts = line.split(" ", 3)
            if len(parts) >= 2 and parts[1] == "001":
                registered = True
                break
            if len(parts) >= 2 and parts[1] in ("432", "433", "436"):
                sys.stderr.write(f"perm-hook: nick reg failed: {line}\n")
                dlog(f"nick reg failed: {line}")
                return None
        if not registered:
            sys.stderr.write("perm-hook: no RPL_WELCOME within 5s\n")
            dlog("no RPL_WELCOME within 5s")
            return None

        send(f"PRIVMSG {TARGET} :{question}")

        for line in read_lines(time.time() + TIMEOUT):
            dlog(f"<- {line}")
            if line.startswith("PING "):
                send("PONG " + line[5:])
                continue
            if not line.startswith(":"):
                continue
            # :alex2!u@h PRIVMSG permbot-... :body...
            try:
                src, cmd, tgt, rest = line[1:].split(" ", 3)
            except ValueError:
                continue
            if cmd != "PRIVMSG" or tgt != nick:
                continue
            src_nick = src.split("!", 1)[0]
            if src_nick != TARGET:
                continue
            body = rest[1:] if rest.startswith(":") else rest
            dlog(f"REPLY from {src_nick}: {body!r}")
            return body.strip()
        dlog("reply window expired with no match")
        return None
    finally:
        try:
            send("QUIT :done")
        except OSError:
            pass
        try:
            sock.close()
        except OSError:
            pass


def main() -> None:
    try:
        payload = json.load(sys.stdin)
    except json.JSONDecodeError as e:
        sys.stderr.write(f"perm-hook: bad stdin JSON: {e}\n")
        emit("ask", "hook input parse error")

    tool_name = payload.get("tool_name", "")
    tool_input = payload.get("tool_input", {}) or {}

    if tool_name.startswith(PASSTHROUGH_PREFIXES):
        emit("allow", "roost-irc passthrough")

    summary = summarize(tool_name, tool_input)
    question = f"[{WORKER}] permission needed: {summary} — reply y/n"

    reply = ask_irc(question)
    if reply is None:
        emit("ask", "irc prompt timed out / failed; falling back to terminal")

    norm = reply.strip().lower()
    if norm in ("y", "yes", "allow", "ok", "approve"):
        emit("allow", f"approved by {TARGET} via IRC")
    if norm in ("n", "no", "deny", "block"):
        emit("deny", f"denied by {TARGET} via IRC: {reply!r}")
    emit("ask", f"unrecognized reply {reply!r}; falling back to terminal")


if __name__ == "__main__":
    main()
