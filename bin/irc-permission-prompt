#!/usr/bin/env python3
"""
roost — PreToolUse hook (thin socket client over the permbot daemon).

Reads PreToolUse JSON on stdin, asks the worker's permbot daemon (over
its unix socket) whether the operator approves, and emits
hookSpecificOutput.permissionDecision = allow|deny|ask.

The daemon (bin/roost-permbot) is what actually talks to IRC. This hook
is just a pipe: stdin payload → one-line JSON request → one-line JSON
response → decision.

If the daemon's socket is missing or unreachable, emit "ask" so the
terminal prompt is still the safety net. Same fallback for ambiguous
replies and timeouts.

Configuration (env, all optional):
  ROOST_PERM_SOCK       Daemon socket path. Defaults to
                        /tmp/roost-permbot-{ROOST_IRC_NICK}.sock
  ROOST_PERM_TIMEOUT    Operator reply timeout (seconds, default 30).
                        Sent to the daemon as part of the request;
                        the local socket-read timeout is timeout + 5.
  ROOST_IRC_NICK        Worker nick (set by bin/roost spawn). Used to
                        derive the default socket path.

Tools whose names start with `mcp__roost-irc__` are passthrough
(allowed without asking) — otherwise the worker couldn't talk on IRC,
including replying to the operator.
"""
import json
import os
import socket
import sys
import time

WORKER = os.environ.get("ROOST_IRC_NICK", "unknown")
SOCK_PATH = os.environ.get(
    "ROOST_PERM_SOCK",
    f"/tmp/roost-permbot-{WORKER}.sock",
)
TIMEOUT = float(os.environ.get("ROOST_PERM_TIMEOUT", "30"))

PASSTHROUGH_PREFIXES = ("mcp__roost-irc__",)


def emit(decision: str, reason: str) -> None:
    if decision == "ask":
        # No decision → Claude Code shows the terminal permission prompt
        sys.stderr.write(f"perm-hook: deferring to terminal ({reason})\n")
        sys.exit(0)
    json.dump(
        {
            "hookSpecificOutput": {
                "hookEventName": "PermissionRequest",
                "decision": {"behavior": decision},
            }
        },
        sys.stdout,
    )
    sys.stdout.write("\n")
    sys.exit(0)


def _clip(s: str, n: int) -> str:
    s = (s or "").replace("\r", " ").replace("\n", " ").strip()
    if len(s) > n:
        return s[: n - 1] + "…"
    return s


def summarize(tool_name: str, tool_input: dict) -> list[str]:
    """Return a list of lines describing the tool call (1+ lines)."""
    lines: list[str] = []
    if tool_name == "Read":
        path = tool_input.get("file_path", "?")
        rng = ""
        offset = tool_input.get("offset")
        limit = tool_input.get("limit")
        if offset or limit:
            start = offset or 1
            end = (offset or 1) + (limit or 0) - 1 if limit else "end"
            rng = f" (lines {start}–{end})"
        lines.append(f"Read {path}{rng}")
    elif tool_name == "Write":
        path = tool_input.get("file_path", "?")
        content = tool_input.get("content", "")
        lines.append(f"Write {path} ({len(content)} bytes)")
        if content:
            lines.append(f"  preview: {_clip(content, 200)}")
    elif tool_name == "Edit":
        path = tool_input.get("file_path", "?")
        old = tool_input.get("old_string", "")
        new = tool_input.get("new_string", "")
        replace_all = tool_input.get("replace_all")
        suffix = " (replace_all)" if replace_all else ""
        lines.append(f"Edit {path}{suffix}")
        lines.append(f"  old: {_clip(old, 160)}")
        lines.append(f"  new: {_clip(new, 160)}")
    elif tool_name == "NotebookEdit":
        path = tool_input.get("notebook_path", "?")
        cell = tool_input.get("cell_id", "?")
        lines.append(f"NotebookEdit {path} cell={cell}")
        new = tool_input.get("new_source", "")
        if new:
            lines.append(f"  new: {_clip(new, 160)}")
    elif tool_name == "Bash":
        desc = tool_input.get("description", "").strip()
        cmd = tool_input.get("command", "")
        head = f"Bash ({desc})" if desc else "Bash"
        lines.append(head)
        lines.append(f"  $ {_clip(cmd, 280)}")
    elif tool_name == "Grep":
        pat = tool_input.get("pattern", "?")
        path = tool_input.get("path", "")
        glob = tool_input.get("glob", "")
        bits = [f"pattern={pat!r}"]
        if path:
            bits.append(f"path={path}")
        if glob:
            bits.append(f"glob={glob}")
        lines.append("Grep " + " ".join(bits))
    elif tool_name == "Glob":
        pat = tool_input.get("pattern", "?")
        path = tool_input.get("path", "")
        lines.append(f"Glob {pat}" + (f" in {path}" if path else ""))
    elif tool_name == "WebFetch":
        url = tool_input.get("url", "?")
        prompt = tool_input.get("prompt", "")
        lines.append(f"WebFetch {url}")
        if prompt:
            lines.append(f"  prompt: {_clip(prompt, 200)}")
    else:
        blob = json.dumps(tool_input, separators=(",", ":"), ensure_ascii=False)
        lines.append(f"{tool_name} {_clip(blob, 240)}")
    return lines


def extract_intent(transcript_path: str) -> str:
    """Pull the most recent assistant text block from the transcript.

    Falls back to thinking content if no text is available, then None.
    Reads the tail of the file to keep this cheap on long sessions.
    """
    if not transcript_path or not os.path.exists(transcript_path):
        return ""
    try:
        size = os.path.getsize(transcript_path)
        with open(transcript_path, "rb") as f:
            f.seek(max(0, size - 200_000))
            data = f.read()
    except OSError:
        return ""
    # The first line after a mid-file seek is likely truncated; drop it.
    raw_lines = data.split(b"\n")
    if size > 200_000 and raw_lines:
        raw_lines = raw_lines[1:]
    fallback_thinking = ""
    for raw in reversed(raw_lines):
        line = raw.strip()
        if not line:
            continue
        try:
            turn = json.loads(line)
        except (json.JSONDecodeError, ValueError):
            continue
        if turn.get("type") != "assistant":
            continue
        content = (turn.get("message") or {}).get("content")
        if not isinstance(content, list):
            continue
        for block in content:
            if not isinstance(block, dict):
                continue
            if block.get("type") == "text":
                text = (block.get("text") or "").strip()
                if text:
                    return _clip(text, 400)
            elif block.get("type") == "thinking" and not fallback_thinking:
                think = (block.get("thinking") or "").strip()
                if think:
                    fallback_thinking = _clip(think, 400)
    return fallback_thinking


def ask_daemon(summary: str):
    """Round-trip a request through the permbot socket. Return reply str or None."""
    if not os.path.exists(SOCK_PATH):
        sys.stderr.write(f"perm-hook: socket {SOCK_PATH} missing\n")
        return None
    try:
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.settimeout(TIMEOUT + 5)
        sock.connect(SOCK_PATH)
    except OSError as e:
        sys.stderr.write(f"perm-hook: connect {SOCK_PATH} failed: {e}\n")
        return None

    try:
        req = json.dumps({"summary": summary, "timeout": TIMEOUT})
        sock.sendall((req + "\n").encode("utf-8"))
        # Read response. Should be one line.
        buf = b""
        deadline = time.time() + TIMEOUT + 5
        while time.time() < deadline and b"\n" not in buf:
            try:
                chunk = sock.recv(4096)
            except socket.timeout:
                break
            if not chunk:
                break
            buf += chunk
        if b"\n" not in buf:
            sys.stderr.write("perm-hook: daemon response truncated\n")
            return None
        line, _, _ = buf.partition(b"\n")
        try:
            resp = json.loads(line.decode("utf-8"))
        except json.JSONDecodeError as e:
            sys.stderr.write(f"perm-hook: bad daemon response: {e}\n")
            return None
        if resp.get("timeout"):
            return None
        if "error" in resp:
            sys.stderr.write(f"perm-hook: daemon error: {resp['error']}\n")
            return None
        return resp.get("reply")
    finally:
        try:
            sock.close()
        except OSError:
            pass


def main() -> None:
    try:
        payload = json.load(sys.stdin)
    except json.JSONDecodeError as e:
        sys.stderr.write(f"perm-hook: bad stdin JSON: {e}\n")
        emit("ask", "hook input parse error")

    tool_name = payload.get("tool_name", "")
    tool_input = payload.get("tool_input", {}) or {}
    transcript_path = payload.get("transcript_path", "")

    if tool_name.startswith(PASSTHROUGH_PREFIXES):
        emit("allow", "roost-irc passthrough")

    intent = extract_intent(transcript_path)
    summary_lines = summarize(tool_name, tool_input)
    if intent:
        summary_lines.append(f"intent: {intent}")
    summary = "\n".join(summary_lines)
    reply = ask_daemon(summary)
    if reply is None:
        emit("ask", "permbot unavailable / timed out; falling back to terminal")

    norm = reply.strip().lower()
    if norm in ("y", "yes", "allow", "ok", "approve"):
        emit("allow", "approved via IRC")
    if norm in ("n", "no", "deny", "block"):
        emit("deny", f"denied via IRC: {reply!r}")
    emit("ask", f"unrecognized reply {reply!r}; falling back to terminal")


if __name__ == "__main__":
    main()
