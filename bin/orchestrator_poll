#!/usr/bin/env python3
"""Orchestrator poll + diff for roost.

GitHub-only. Reads .orchestrator/config.json, snapshots GitHub state for
watched issues and PRs, diffs against .orchestrator/state.json, and publishes
events to IRC channels named #issue-{number}.

Modes:
    bin/orchestrator_poll              # one-shot tick, prints events JSON
    bin/orchestrator_poll --seed       # force re-seed, emit []
    bin/orchestrator_poll --dispatch-irc  # one-shot IRC dispatch
    bin/orchestrator_poll --daemon     # long-running poll/dispatch loop
    bin/orchestrator_poll --dry-run    # fetch + diff, no persistence

Config (.orchestrator/config.json):

    {
      "repo": "AlexSc/roost",
      "agent_logins": ["TeakBuilds"],
      "irc": {
        "nick": "dispatcher-roost",
        "project_channel": "#roost",
        "server": "127.0.0.1",
        "port": 6667,
        "interval_seconds": 60
      },
      "watched_prs": [22],
      "watched_issues": [15]
    }

watched_prs and watched_issues accept bare ints (uses top-level repo) or
dicts with optional repo override: {"repo": "OWNER/NAME", "number": N}.

Events route automatically to #issue-{number}. project_channel is the
fallback for project-level events (dispatcher errors, etc.).
"""
from __future__ import annotations

import argparse
import json
import os
import pathlib
import select
import signal
import socket
import subprocess
import sys
import tempfile
import random
import re
import time
import traceback
from datetime import datetime, timezone
from typing import Any, Iterable

REPO_ROOT = pathlib.Path(__file__).resolve().parent.parent
STATE_DIR = REPO_ROOT / ".orchestrator"
CONFIG_PATH = STATE_DIR / "config.json"
STATE_PATH = STATE_DIR / "state.json"
HEARTBEAT_PATH = STATE_DIR / "last-tick.txt"
LAST_ERROR_PATH = STATE_DIR / "last-error.txt"

SCHEMA_VERSION = 1

# Per-line PRIVMSG body cap inside a draft/multiline batch. Matches
# MULTILINE_LINE_BYTES in irc-lib.ts. IRC wire limit is 512 bytes total;
# 300 is conservative-safe without knowing the server's prefix length at runtime.
MULTILINE_LINE_BYTES = 300

CAP_MULTILINE = "draft/multiline"


class GhError(RuntimeError):
    pass


# ---------------------------------------------------------------------------
# gh shell-out
# ---------------------------------------------------------------------------

def _gh(cmd: list[str]) -> Any:
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        raise GhError(
            f"gh failed (exit {result.returncode}): {' '.join(cmd)}\n"
            f"{(result.stderr or '').strip()}"
        )
    out = result.stdout.strip()
    if not out:
        return None
    try:
        return json.loads(out)
    except json.JSONDecodeError:
        return out


def gh_api(endpoint: str, paginate: bool = False) -> Any:
    cmd = ["gh", "api"]
    if paginate:
        cmd.append("--paginate")
    cmd.append(endpoint)
    return _gh(cmd)


# ---------------------------------------------------------------------------
# State / config IO
# ---------------------------------------------------------------------------

def load_config() -> dict:
    if not CONFIG_PATH.exists():
        sys.stderr.write(f"config missing: {CONFIG_PATH}\n")
        raise RuntimeError(f"config missing: {CONFIG_PATH}")
    return json.loads(CONFIG_PATH.read_text())


def load_state() -> dict | None:
    if not STATE_PATH.exists():
        return None
    text = STATE_PATH.read_text().strip()
    if not text:
        return None
    state = json.loads(text)
    if state.get("schema_version") != SCHEMA_VERSION:
        sys.stderr.write(
            f"state.json schema mismatch: got {state.get('schema_version')}, "
            f"expected {SCHEMA_VERSION}; re-seeding.\n"
        )
        return None
    return state


def write_state(state: dict) -> None:
    STATE_DIR.mkdir(exist_ok=True)
    tmp_fd, tmp_path = tempfile.mkstemp(dir=STATE_DIR, prefix=".state.", suffix=".tmp")
    try:
        with os.fdopen(tmp_fd, "w") as f:
            json.dump(state, f, indent=2, sort_keys=True)
            f.write("\n")
        os.replace(tmp_path, STATE_PATH)
    except Exception:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass
        raise


def write_heartbeat() -> None:
    STATE_DIR.mkdir(exist_ok=True)
    HEARTBEAT_PATH.write_text(datetime.now(timezone.utc).isoformat() + "\n")


# ---------------------------------------------------------------------------
# CI rollup + label helpers
# ---------------------------------------------------------------------------

def _aggregate_ci(runs: list[dict], statuses: list[dict]) -> str | None:
    """Aggregate check-runs + combined-status into PENDING / SUCCESS / FAILURE."""
    states: set[str] = set()
    for run in runs or []:
        status = (run.get("status") or "").upper()
        if status in ("IN_PROGRESS", "QUEUED", "PENDING", "WAITING"):
            states.add("PENDING")
            continue
        conclusion = (run.get("conclusion") or "").upper()
        if conclusion in ("SUCCESS", "NEUTRAL", "SKIPPED"):
            states.add("SUCCESS")
        elif conclusion in ("FAILURE", "TIMED_OUT", "CANCELLED", "ACTION_REQUIRED", "STARTUP_FAILURE"):
            states.add("FAILURE")
        else:
            states.add("PENDING")
    for st in statuses or []:
        s = (st.get("state") or "").upper()
        if s == "SUCCESS":
            states.add("SUCCESS")
        elif s in ("FAILURE", "ERROR"):
            states.add("FAILURE")
        else:
            states.add("PENDING")
    if not states:
        return None
    if "FAILURE" in states:
        return "FAILURE"
    if "PENDING" in states:
        return "PENDING"
    return "SUCCESS"


def label_names(labels: Any) -> list[str]:
    if not labels:
        return []
    out: list[str] = []
    for label in labels:
        if isinstance(label, dict):
            n = label.get("name")
            if n:
                out.append(n)
        elif isinstance(label, str):
            out.append(label)
    return sorted(out)


# ---------------------------------------------------------------------------
# GitHub fetchers
# ---------------------------------------------------------------------------

def fetch_pr(repo: str, number: int) -> dict:
    pr = gh_api(f"repos/{repo}/pulls/{number}") or {}
    head = pr.get("head") or {}
    sha = head.get("sha")

    runs: list[dict] = []
    statuses: list[dict] = []
    if sha:
        check_runs_resp = gh_api(
            f"repos/{repo}/commits/{sha}/check-runs?per_page=100",
            paginate=True,
        )
        if isinstance(check_runs_resp, dict):
            runs = check_runs_resp.get("check_runs") or []
        elif isinstance(check_runs_resp, list):
            runs = check_runs_resp
        combined = gh_api(f"repos/{repo}/commits/{sha}/status") or {}
        statuses = combined.get("statuses") or []

    return {
        "title": pr.get("title"),
        "url": pr.get("html_url"),
        "head_ref": head.get("ref"),
        "head_oid": sha,
        "is_draft": bool(pr.get("draft")),
        "merged_at": pr.get("merged_at"),
        "state": (pr.get("state") or "").upper(),
        "labels": pr.get("labels") or [],
        "ci_state": _aggregate_ci(runs, statuses),
    }


def fetch_pr_review_comments(repo: str, number: int) -> list[dict]:
    return gh_api(f"repos/{repo}/pulls/{number}/comments?per_page=100", paginate=True) or []


def fetch_pr_conversation_comments(repo: str, number: int) -> list[dict]:
    return gh_api(f"repos/{repo}/issues/{number}/comments?per_page=100", paginate=True) or []


def fetch_pr_reviews(repo: str, number: int) -> list[dict]:
    return gh_api(f"repos/{repo}/pulls/{number}/reviews?per_page=100", paginate=True) or []


def fetch_pr_linked_issues(repo: str, number: int) -> list[int]:
    owner, name = repo.split("/", 1)
    query = (
        "query($owner:String!,$name:String!,$number:Int!){"
        "repository(owner:$owner,name:$name){"
        "pullRequest(number:$number){"
        "closingIssuesReferences(first:25){nodes{number}}}}}"
    )
    result = _gh(["gh", "api", "graphql",
                  "-f", f"query={query}",
                  "-F", f"owner={owner}",
                  "-F", f"name={name}",
                  "-F", f"number={number}"])
    if not result:
        return []
    nodes = (
        (result.get("data") or {})
        .get("repository", {})
        .get("pullRequest", {})
        .get("closingIssuesReferences", {})
        .get("nodes") or []
    )
    return sorted(n["number"] for n in nodes if n.get("number") is not None)


def fetch_issue(repo: str, number: int) -> dict:
    return gh_api(f"repos/{repo}/issues/{number}")


def fetch_issue_comments(repo: str, number: int) -> list[dict]:
    return gh_api(f"repos/{repo}/issues/{number}/comments?per_page=100", paginate=True) or []


# ---------------------------------------------------------------------------
# Snapshots
# ---------------------------------------------------------------------------

def snapshot_pr(repo: str, number: int, prev_snap: dict | None = None) -> dict:
    view = fetch_pr(repo, number)
    review_comments = fetch_pr_review_comments(repo, number)
    conv_comments = fetch_pr_conversation_comments(repo, number)
    reviews = fetch_pr_reviews(repo, number)
    cur_head = view.get("head_oid")
    # Re-use cached linked_issues when head hasn't changed; closing issues are
    # stable per branch so a new fetch is only needed on a new push.
    if prev_snap and prev_snap.get("head_oid") == cur_head:
        linked_issues = prev_snap.get("linked_issues") or []
    else:
        linked_issues = fetch_pr_linked_issues(repo, number)
    return {
        "repo": repo,
        "number": number,
        "title": view.get("title"),
        "url": view.get("url"),
        "head_ref": view.get("head_ref"),
        "head_oid": cur_head,
        "is_draft": view.get("is_draft", False),
        "merged": view.get("merged_at") is not None,
        "state": view.get("state"),
        "labels": label_names(view.get("labels")),
        "ci_state": view.get("ci_state"),
        "linked_issues": linked_issues,
        "seen_review_comment_ids": sorted(c["id"] for c in review_comments if c.get("id") is not None),
        "seen_conversation_comment_ids": sorted(c["id"] for c in conv_comments if c.get("id") is not None),
        "seen_review_ids": sorted(r["id"] for r in reviews if r.get("id") is not None),
        "_review_comments_by_id": {c["id"]: c for c in review_comments if c.get("id") is not None},
        "_conversation_comments_by_id": {c["id"]: c for c in conv_comments if c.get("id") is not None},
        "_reviews_by_id": {r["id"]: r for r in reviews if r.get("id") is not None},
    }


def snapshot_issue(repo: str, number: int) -> dict:
    issue = fetch_issue(repo, number)
    comments = fetch_issue_comments(repo, number)
    return {
        "repo": repo,
        "number": number,
        "title": issue.get("title"),
        "url": issue.get("html_url"),
        "state": issue.get("state"),
        "labels": label_names(issue.get("labels")),
        "seen_comment_ids": sorted(c["id"] for c in comments if c.get("id") is not None),
        "_comments_by_id": {c["id"]: c for c in comments if c.get("id") is not None},
    }


def strip_internals(snap: dict) -> dict:
    return {k: v for k, v in snap.items() if not k.startswith("_")}


def _pr_key(repo: str, number: int) -> str:
    return f"{repo}#{number}"


def _issue_key(repo: str, number: int) -> str:
    return f"{repo}#{number}"


# ---------------------------------------------------------------------------
# Diffs
# ---------------------------------------------------------------------------

def format_comment_event(c: dict, *, kind: str, repo: str | None, pr: int | None,
                         issue: int | None, url: str,
                         agent_logins: set[str] | None = None,
                         linked_issues: list[int] | None = None) -> dict:
    author = (c.get("user") or {}).get("login")
    body = c.get("body") or ""
    is_agent_author = bool(agent_logins) and author in (agent_logins or set())
    stripped = body.lstrip()
    has_agent_prefix = (stripped.startswith("[worker-")
                        or stripped.startswith("[lead-")
                        or stripped.startswith("[reviewer-"))
    is_worker = is_agent_author or has_agent_prefix
    ev: dict = {
        "kind": kind,
        "comment_id": c.get("id"),
        "comment_url": c.get("html_url"),
        "author": author,
        "is_worker_reply": is_worker,
        "body": body,
        "body_preview": body[:280],
    }
    if repo:
        ev["repo"] = repo
    if pr is not None:
        ev["pr"] = pr
        ev["pr_url"] = url
        if linked_issues:
            ev["linked_issues"] = linked_issues
    if issue is not None:
        ev["issue"] = issue
        ev["issue_url"] = url
    if "path" in c:
        ev["path"] = c.get("path")
        ev["line"] = c.get("line") or c.get("original_line")
    return ev


def diff_pr(prev: dict, cur: dict, agent_logins: set[str] | None = None) -> list[dict]:
    events: list[dict] = []
    n = cur["number"]
    repo = cur["repo"]
    linked = cur.get("linked_issues") or []
    base: dict = {"repo": repo, "pr": n, "url": cur["url"], "title": cur["title"]}
    if linked:
        base["linked_issues"] = linked

    if prev.get("is_draft") and not cur["is_draft"]:
        events.append({"kind": "pr_ready_for_review", **base})
    if not prev.get("is_draft") and cur["is_draft"]:
        events.append({"kind": "pr_returned_to_draft", **base})

    if not prev.get("merged") and cur["merged"]:
        events.append({"kind": "pr_merged", **base})
    elif prev.get("state") == "OPEN" and cur["state"] == "CLOSED" and not cur["merged"]:
        events.append({"kind": "pr_closed", **base})

    prev_labels = set(prev.get("labels") or [])
    cur_labels = set(cur.get("labels") or [])
    if prev_labels != cur_labels:
        events.append({
            **base,
            "kind": "labels_changed",
            "subject": "pr",
            "added": sorted(cur_labels - prev_labels),
            "removed": sorted(prev_labels - cur_labels),
        })

    # Track head_oid so a new push landing at the same terminal CI state
    # still fires a ci_transitioned event for the new commit.
    prev_head = prev.get("head_oid")
    cur_head = cur.get("head_oid")
    prev_ci = prev.get("ci_state")
    cur_ci = cur.get("ci_state")
    head_changed = prev_head != cur_head
    if head_changed and cur_ci in ("SUCCESS", "FAILURE"):
        ci_ev: dict = {
            "kind": "ci_transitioned",
            "repo": repo, "pr": n, "url": cur["url"],
            "from": "PENDING", "to": cur_ci, "head_oid": cur_head,
        }
        if linked:
            ci_ev["linked_issues"] = linked
        events.append(ci_ev)
    elif not head_changed and prev_ci != cur_ci:
        ci_ev = {
            "kind": "ci_transitioned",
            "repo": repo, "pr": n, "url": cur["url"],
            "from": prev_ci, "to": cur_ci, "head_oid": cur_head,
        }
        if linked:
            ci_ev["linked_issues"] = linked
        events.append(ci_ev)

    prev_rc = set(prev.get("seen_review_comment_ids") or [])
    cur_rc_idx = cur["_review_comments_by_id"]
    for cid in sorted(set(cur_rc_idx) - prev_rc):
        events.append(format_comment_event(cur_rc_idx[cid], kind="pr_review_comment",
                                           repo=repo, pr=n, issue=None,
                                           url=cur["url"], agent_logins=agent_logins,
                                           linked_issues=linked))

    prev_cc = set(prev.get("seen_conversation_comment_ids") or [])
    cur_cc_idx = cur["_conversation_comments_by_id"]
    for cid in sorted(set(cur_cc_idx) - prev_cc):
        events.append(format_comment_event(cur_cc_idx[cid], kind="pr_conversation_comment",
                                           repo=repo, pr=n, issue=None,
                                           url=cur["url"], agent_logins=agent_logins,
                                           linked_issues=linked))

    prev_rev = set(prev.get("seen_review_ids") or [])
    cur_rev_idx = cur.get("_reviews_by_id") or {}
    for rid in sorted(set(cur_rev_idx) - prev_rev):
        review = cur_rev_idx[rid]
        author = (review.get("user") or {}).get("login")
        is_agent_author = bool(agent_logins) and author in (agent_logins or set())
        rev_ev: dict = {
            "kind": "pr_review_submitted",
            "repo": repo, "pr": n, "url": cur["url"],
            "review_id": rid,
            "review_url": review.get("html_url"),
            "author": author,
            "state": (review.get("state") or "").upper(),
            "body": (review.get("body") or ""),
            "body_preview": (review.get("body") or "")[:280],
            "is_worker_reply": is_agent_author,
        }
        if linked:
            rev_ev["linked_issues"] = linked
        events.append(rev_ev)

    return events


def diff_issue(prev: dict, cur: dict, agent_logins: set[str] | None = None) -> list[dict]:
    events: list[dict] = []
    n = cur["number"]
    repo = cur["repo"]

    if prev.get("state") != cur.get("state"):
        events.append({
            "kind": "issue_state_changed",
            "repo": repo, "issue": n, "url": cur["url"],
            "from": prev.get("state"), "to": cur.get("state"),
        })

    prev_labels = set(prev.get("labels") or [])
    cur_labels = set(cur.get("labels") or [])
    if prev_labels != cur_labels:
        events.append({
            "kind": "labels_changed",
            "subject": "issue",
            "repo": repo, "issue": n, "url": cur["url"],
            "added": sorted(cur_labels - prev_labels),
            "removed": sorted(prev_labels - cur_labels),
        })

    prev_c = set(prev.get("seen_comment_ids") or [])
    cur_c_idx = cur["_comments_by_id"]
    for cid in sorted(set(cur_c_idx) - prev_c):
        events.append(format_comment_event(cur_c_idx[cid], kind="issue_comment",
                                           repo=repo, pr=None, issue=n,
                                           url=cur["url"], agent_logins=agent_logins))

    return events


# ---------------------------------------------------------------------------
# Classification
# ---------------------------------------------------------------------------

SKIP_KINDS = {"pr_added_to_watch", "issue_added_to_watch"}

ALWAYS_PUSH_KINDS = {
    "pr_ready_for_review",
    "pr_returned_to_draft",
    "pr_merged",
    "pr_closed",
    "pr_has_existing_comments",
    "pr_has_existing_ci_state",
    "issue_has_existing_comments",
    "dispatcher_error",
}

MEANINGFUL_LABEL_PREFIXES = ("phase:", "plan:")
MEANINGFUL_LABELS_EXACT = {"ready-for-merge"}


def should_push(event: dict) -> bool:
    kind = event.get("kind")
    if kind in SKIP_KINDS:
        return False
    if kind in ALWAYS_PUSH_KINDS:
        return True
    if kind in ("pr_review_comment", "pr_conversation_comment", "issue_comment", "pr_review_submitted"):
        return True
    if kind == "ci_transitioned":
        return event.get("to") in ("SUCCESS", "FAILURE")
    if kind == "labels_changed":
        changed = set(event.get("added") or []) | set(event.get("removed") or [])
        for label in changed:
            if any(label.startswith(p) for p in MEANINGFUL_LABEL_PREFIXES):
                return True
            if label in MEANINGFUL_LABELS_EXACT:
                return True
        return False
    if kind == "issue_state_changed":
        return event.get("to") == "closed"
    return True


# ---------------------------------------------------------------------------
# Channel formatting
# ---------------------------------------------------------------------------

def _comment_snippet(event: dict) -> tuple[str, str, str]:
    body_preview = (event.get("body_preview") or "").strip()
    snippet_lines = body_preview.splitlines()
    snippet = snippet_lines[0][:160] if snippet_lines else ""
    ellipsis = "…" if len(body_preview) > len(snippet) or len(snippet_lines) > 1 else ""
    url = event.get("comment_url") or event.get("url", "")
    return snippet, ellipsis, url


def _event_tag(event: dict) -> str:
    n = event.get("pr") or event.get("issue")
    repo = event.get("repo")
    return f"{repo}#{n}" if (n is not None and repo) else (f"#{n}" if n is not None else "")


def format_event(event: dict) -> str:
    kind = event.get("kind") or "unknown"
    tag = _event_tag(event)

    if kind == "pr_ready_for_review":
        return f"PR {tag} ready for review: {event.get('title', '')} — {event.get('url', '')}"
    if kind == "pr_returned_to_draft":
        return f"PR {tag} returned to draft: {event.get('title', '')} — {event.get('url', '')}"
    if kind == "pr_merged":
        return f"PR {tag} merged: {event.get('title', '')} — {event.get('url', '')}"
    if kind == "pr_closed":
        return f"PR {tag} closed (not merged): {event.get('title', '')} — {event.get('url', '')}"
    if kind in ("pr_review_comment", "pr_conversation_comment"):
        author = event.get("author") or "?"
        path = event.get("path")
        line = event.get("line")
        where = f" at {path}:{line}" if path else ""
        snippet, ellipsis, url = _comment_snippet(event)
        return f"PR {tag} comment by {author}{where}: {snippet}{ellipsis} — {url}"
    if kind == "issue_comment":
        author = event.get("author") or "?"
        snippet, ellipsis, url = _comment_snippet(event)
        return f"Issue {tag} comment by {author}: {snippet}{ellipsis} — {url}"
    if kind == "pr_review_submitted":
        author = event.get("author") or "?"
        state = event.get("state") or "?"
        snippet = (event.get("body_preview") or "").strip().splitlines()[:1]
        snippet = (": " + snippet[0][:160]) if snippet else ""
        return f"PR {tag} review by {author} ({state}){snippet} — {event.get('review_url') or event.get('url', '')}"
    if kind == "ci_transitioned":
        return f"PR {tag} CI: {event.get('from')} → {event.get('to')}"
    if kind == "labels_changed":
        added = event.get("added") or []
        removed = event.get("removed") or []
        parts = []
        if added:
            parts.append("+" + ",".join(added))
        if removed:
            parts.append("-" + ",".join(removed))
        return f"{tag} labels: {' '.join(parts)}"
    if kind == "issue_state_changed":
        return f"Issue {tag} state: {event.get('from')} → {event.get('to')}"
    if kind == "pr_has_existing_comments":
        rc = event.get("review_comment_count", 0)
        cc = event.get("conversation_comment_count", 0)
        return (f"PR {tag} BACKLOG: {rc} review + {cc} conversation comments "
                f"existed before watch — scan manually: {event.get('url', '')}")
    if kind == "pr_has_existing_ci_state":
        return (f"PR {tag} CI already terminal at watch time: "
                f"{event.get('ci_state')} — {event.get('url', '')}")
    if kind == "issue_has_existing_comments":
        cc = event.get("comment_count", 0)
        return (f"Issue {tag} BACKLOG: {cc} comments existed before watch — "
                f"scan manually: {event.get('url', '')}")
    if kind == "dispatcher_error":
        tb = (event.get("stderr") or "").strip().splitlines()
        first = tb[-1] if tb else "(no detail)"
        return f"DISPATCHER ERROR at {event.get('tick_utc', '')}: {first}"
    return f"[{kind}] {json.dumps(event, ensure_ascii=False)[:280]}"


# ---------------------------------------------------------------------------
# IRC client
# ---------------------------------------------------------------------------

IRC_MAX_CHUNK_BODY = 300


def _utf8_split(text: str, limit: int, *, boundary: bool) -> list[str]:
    """Split text into ≤limit-byte chunks. boundary=True seeks sentence/word breaks."""
    if len(text.encode("utf-8")) <= limit:
        return [text]
    out: list[str] = []
    s = text
    while s:
        if len(s.encode("utf-8")) <= limit:
            out.append(s)
            break
        end = min(len(s), limit)
        while end > 0 and len(s[:end].encode("utf-8")) > limit:
            end -= 1
        if boundary:
            min_viable = max(1, end * 2 // 3)
            split_at = end
            for j in range(end, min_viable, -1):
                if j < len(s) and s[j - 1] in ".!?" and (j == len(s) or s[j] in " \t\n"):
                    split_at = j
                    break
            else:
                for j in range(end, min_viable, -1):
                    if j < len(s) and s[j] in " \t":
                        split_at = j
                        break
        else:
            split_at = end
        out.append(s[:split_at])
        s = s[split_at:]
    return out


def _irc_split_text(text: str) -> list[str]:
    return _utf8_split(text, IRC_MAX_CHUNK_BODY, boundary=True)


def _multiline_split_line(line: str) -> list[str]:
    return _utf8_split(line, MULTILINE_LINE_BYTES, boundary=False)


# Matches: `:server CAP <nick> <sub> [*] :<caps>`
# group 1 = subcommand, group 2 = "*" (non-final LS) or None, group 3 = caps string
_RE_CAP = re.compile(r'^:\S+ CAP \S+ (\w+)(?: (\*))?(?:\s+:?(.*))?')
_RE_001 = re.compile(r'^:\S+ 001 ')
# Matches the draft/multiline cap token; group 1 = "key=val,…" params or None
_RE_MULTILINE_CAP = re.compile(r'(?:^|\s)draft/multiline(?:=(\S+))?(?:\s|$)')
_RE_MULTILINE_PARAMS = re.compile(r'max-bytes=(\d+)|max-lines=(\d+)')


class IrcClient:
    def __init__(self, server: str, port: int, nick: str, default_channels: Iterable[str] = ()):
        self.server = server
        self.port = int(port)
        self.nick = nick
        self.default_channels = list(default_channels)
        self.sock: socket.socket | None = None
        self._buffer = ""
        self._joined: set[str] = set()
        self._reset_multiline_state()

    def _reset_multiline_state(self) -> None:
        self._multiline_enabled = False
        self._multiline_max_bytes = 16384
        self._multiline_max_lines = 200

    def connect(self) -> None:
        s = socket.create_connection((self.server, self.port), timeout=10)
        s.settimeout(0.0)
        self.sock = s
        self._buffer = ""
        self._joined = set()
        self._reset_multiline_state()
        self._send_raw("CAP LS 302")
        self._send_raw(f"NICK {self.nick}")
        self._send_raw(f"USER {self.nick} 0 * :{self.nick}")
        deadline = time.time() + 10
        registered = False
        _cap_req_sent = False
        while time.time() < deadline and not registered:
            for line in self._read_lines(timeout=1.0):
                if line.startswith("PING "):
                    self._send_raw("PONG " + line[5:])
                    continue
                cap = _RE_CAP.match(line)
                if cap:
                    sub, is_cont, caps = cap.group(1), cap.group(2), cap.group(3) or ""
                    if sub == "LS":
                        ml = _RE_MULTILINE_CAP.search(caps)
                        if ml and not _cap_req_sent:
                            for mp in _RE_MULTILINE_PARAMS.finditer(ml.group(1) or ""):
                                if mp.group(1):
                                    self._multiline_max_bytes = int(mp.group(1))
                                if mp.group(2):
                                    self._multiline_max_lines = int(mp.group(2))
                            self._send_raw(f"CAP REQ :{CAP_MULTILINE}")
                            _cap_req_sent = True
                        if is_cont is None and not _cap_req_sent:
                            self._send_raw("CAP END")
                    elif sub == "ACK":
                        self._multiline_enabled = True
                        self._send_raw("CAP END")
                    elif sub == "NAK":
                        self._send_raw("CAP END")
                elif _RE_001.match(line):
                    registered = True
                    break
        if not registered:
            raise RuntimeError(f"IRC registration to {self.server}:{self.port} timed out")
        for ch in self.default_channels:
            self.join(ch)

    def reconnect(self) -> None:
        self.close()
        time.sleep(2.0)
        self.connect()

    def close(self) -> None:
        if self.sock is not None:
            try:
                self._send_raw("QUIT :restarting")
            except Exception:
                pass
            try:
                self.sock.close()
            except Exception:
                pass
        self.sock = None
        self._joined = set()
        self._buffer = ""

    def _send_raw(self, line: str) -> None:
        if self.sock is None:
            raise ConnectionError("socket not connected")
        data = (line + "\r\n").encode("utf-8", "replace")
        try:
            self.sock.sendall(data)
        except (OSError, socket.error) as e:
            raise ConnectionError(f"send failed: {e}") from e

    def _read_lines(self, timeout: float = 0.0) -> list[str]:
        if self.sock is None:
            raise ConnectionError("socket not connected")
        try:
            ready, _, _ = select.select([self.sock], [], [], timeout)
        except (OSError, ValueError) as e:
            raise ConnectionError(f"select failed: {e}") from e
        if not ready:
            return []
        try:
            chunk = self.sock.recv(4096)
        except (BlockingIOError, OSError) as e:
            if isinstance(e, BlockingIOError):
                return []
            raise ConnectionError(f"recv failed: {e}") from e
        if not chunk:
            raise ConnectionError("server closed connection")
        self._buffer += chunk.decode("utf-8", "replace")
        out: list[str] = []
        while "\r\n" in self._buffer:
            line, self._buffer = self._buffer.split("\r\n", 1)
            if line:
                out.append(line)
        return out

    def pump(self, timeout: float = 0.0) -> None:
        for line in self._read_lines(timeout=timeout):
            if line.startswith("PING "):
                self._send_raw("PONG " + line[5:])

    def join(self, channel: str) -> None:
        if channel in self._joined:
            return
        self._send_raw(f"JOIN {channel}")
        self._joined.add(channel)

    def part(self, channel: str) -> None:
        if channel not in self._joined:
            return
        self._send_raw(f"PART {channel}")
        self._joined.discard(channel)

    def privmsg(self, channel: str, text: str) -> None:
        self.join(channel)
        for chunk in _irc_split_text(text):
            safe = chunk.replace("\r\n", " ").replace("\n", " ").replace("\r", " ")
            self._send_raw(f"PRIVMSG {channel} :{safe}")
            self.pump(timeout=0.0)

    def comment_privmsg(self, channel: str, header: str, body: str, url: str, fallback: str) -> None:
        """Non-multiline clients still see the URL as a regular PRIVMSG in the flood."""
        if self._multiline_enabled:
            logical_lines = [header] + body.splitlines() + [url]
            wire_lines: list[tuple[str, bool]] = []
            for logical in logical_lines:
                chunks = _multiline_split_line(logical)
                for i, chunk in enumerate(chunks):
                    wire_lines.append((chunk, i > 0))
            if (len(wire_lines) <= self._multiline_max_lines
                    and len(wire_lines) * MULTILINE_LINE_BYTES <= self._multiline_max_bytes):
                self.join(channel)
                batch_id = f"{random.randint(0, 0xffffffff):08x}"
                self._send_raw(f"BATCH +{batch_id} {CAP_MULTILINE} {channel}")
                for text, is_concat in wire_lines:
                    tag = (f"batch={batch_id};draft/multiline-concat" if is_concat
                           else f"batch={batch_id}")
                    self._send_raw(f"@{tag} PRIVMSG {channel} :{text}")
                    self.pump(timeout=0.0)
                self._send_raw(f"BATCH -{batch_id}")
                return
        self.privmsg(channel, fallback)


# ---------------------------------------------------------------------------
# IRC dispatch
# ---------------------------------------------------------------------------

MULTILINE_COMMENT_KINDS = {
    "pr_review_comment",
    "pr_conversation_comment",
    "issue_comment",
    "pr_review_submitted",
}


def _format_comment_header(event: dict) -> str:
    """Header line for a comment event — same as format_event minus snippet and URL."""
    kind = event.get("kind") or ""
    tag = _event_tag(event)
    if kind in ("pr_review_comment", "pr_conversation_comment"):
        author = event.get("author") or "?"
        path = event.get("path")
        line = event.get("line")
        where = f" at {path}:{line}" if path else ""
        return f"PR {tag} comment by {author}{where}:"
    if kind == "issue_comment":
        author = event.get("author") or "?"
        return f"Issue {tag} comment by {author}:"
    if kind == "pr_review_submitted":
        author = event.get("author") or "?"
        state = event.get("state") or "?"
        return f"PR {tag} review by {author} ({state}):"
    return ""


def _event_channels(event: dict, default_channel: str) -> list[str]:
    if event.get("pr") is not None:
        linked = event.get("linked_issues") or []
        if linked:
            return [f"#issue-{n}" for n in linked]
        return [f"#issue-{event['pr']}"]
    if event.get("issue") is not None:
        return [f"#issue-{event['issue']}"]
    return [default_channel]


def _initial_irc_channels(config: dict, project_channel: str) -> list[str]:
    chans: set[str] = {project_channel}
    default_repo = config.get("repo")
    for entry in config.get("watched_prs") or []:
        _, n = _coerce_repo_entry(entry, default_repo)
        chans.add(f"#issue-{n}")
    for entry in config.get("watched_issues") or []:
        _, n = _coerce_repo_entry(entry, default_repo)
        chans.add(f"#issue-{n}")
    state = load_state()
    if state:
        for snap in (state.get("prs") or {}).values():
            for linked_n in (snap.get("linked_issues") or []):
                chans.add(f"#issue-{linked_n}")
    return sorted(chans)


def dispatch_events_irc(events: list[dict], irc: IrcClient, default_channel: str) -> None:
    failures: list[str] = []
    for ev in events:
        if not should_push(ev):
            continue
        targets = _event_channels(ev, default_channel)
        kind = ev.get("kind", "")
        if kind in MULTILINE_COMMENT_KINDS:
            header = _format_comment_header(ev)
            body = ev.get("body") or ""
            url = ev.get("comment_url") or ev.get("review_url") or ev.get("url", "")
            fallback = format_event(ev)
        else:
            text = format_event(ev)
        for target in dict.fromkeys(targets):  # de-dup, preserve order
            try:
                if kind in MULTILINE_COMMENT_KINDS:
                    irc.comment_privmsg(target, header, body, url, fallback)
                else:
                    irc.privmsg(target, text)
            except ConnectionError:
                raise
            except Exception as e:
                failures.append(f"{ev.get('kind')} -> {target}: {e}")
    if failures:
        raise RuntimeError("; ".join(failures))


# ---------------------------------------------------------------------------
# Tick
# ---------------------------------------------------------------------------

def _coerce_repo_entry(entry: Any, default_repo: str | None) -> tuple[str, int]:
    if isinstance(entry, dict):
        repo = entry.get("repo") or default_repo
        number = entry.get("number")
        if not repo or number is None:
            raise RuntimeError(f"watched entry missing repo or number: {entry}")
        return repo, int(number)
    if isinstance(entry, int):
        if not default_repo:
            raise RuntimeError(
                f"bare-int watched entry {entry} requires a top-level `repo` in config"
            )
        return default_repo, entry
    raise RuntimeError(f"unrecognized watched entry shape: {entry!r}")


def _run_one_tick_collect(args: argparse.Namespace, config: dict) -> list[dict]:
    default_repo = config.get("repo")
    watched_prs = list(config.get("watched_prs") or [])
    watched_issues = list(config.get("watched_issues") or [])
    agent_logins = set(config.get("agent_logins") or [])

    prev = None if args.seed else load_state()
    seeding = prev is None

    cur_state: dict = {
        "schema_version": SCHEMA_VERSION,
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "prs": {},
        "issues": {},
    }
    events: list[dict] = []

    for entry in watched_prs:
        repo, number = _coerce_repo_entry(entry, default_repo)
        key = _pr_key(repo, number)
        prev_pr = (prev.get("prs") or {}).get(key) if (prev and not seeding) else None
        snap = snapshot_pr(repo, number, prev_snap=prev_pr)
        if not seeding:
            if prev_pr:
                events.extend(diff_pr(prev_pr, snap, agent_logins=agent_logins))
            else:
                existing_rev = list(snap.get("seen_review_comment_ids") or [])
                existing_conv = list(snap.get("seen_conversation_comment_ids") or [])
                linked = snap.get("linked_issues") or []
                seed_base: dict = {"repo": repo, "pr": number,
                                   "url": snap["url"], "title": snap["title"]}
                if linked:
                    seed_base["linked_issues"] = linked
                events.append({"kind": "pr_added_to_watch", **seed_base})
                if existing_rev or existing_conv:
                    events.append({"kind": "pr_has_existing_comments",
                                   "review_comment_count": len(existing_rev),
                                   "conversation_comment_count": len(existing_conv),
                                   **seed_base})
                if snap.get("ci_state") in ("SUCCESS", "FAILURE"):
                    events.append({"kind": "pr_has_existing_ci_state",
                                   "ci_state": snap["ci_state"],
                                   **seed_base})
        cur_state["prs"][key] = strip_internals(snap)

    for entry in watched_issues:
        repo, number = _coerce_repo_entry(entry, default_repo)
        snap = snapshot_issue(repo, number)
        key = _issue_key(repo, number)
        if not seeding:
            prev_issue = (prev.get("issues") or {}).get(key) if prev else None
            if prev_issue:
                events.extend(diff_issue(prev_issue, snap, agent_logins=agent_logins))
            else:
                existing_cmts = list(snap.get("seen_comment_ids") or [])
                events.append({"kind": "issue_added_to_watch", "repo": repo, "issue": number,
                                "url": snap["url"], "title": snap["title"]})
                if existing_cmts:
                    events.append({"kind": "issue_has_existing_comments", "repo": repo, "issue": number,
                                   "url": snap["url"], "title": snap["title"],
                                   "comment_count": len(existing_cmts)})
        cur_state["issues"][key] = strip_internals(snap)

    if not args.dry_run:
        write_state(cur_state)
        write_heartbeat()
        try:
            LAST_ERROR_PATH.unlink()
        except FileNotFoundError:
            pass

    return [] if seeding else events


# ---------------------------------------------------------------------------
# Daemon
# ---------------------------------------------------------------------------

def _run_daemon(args: argparse.Namespace) -> int:
    config = load_config()
    irc_cfg = config.get("irc") or {}
    nick = irc_cfg.get("nick")
    if not nick:
        raise RuntimeError("daemon mode requires `irc.nick` in config")
    project_channel = irc_cfg.get("project_channel") or "#general"
    server = irc_cfg.get("server", "127.0.0.1")
    port = int(irc_cfg.get("port", 6667))
    interval = max(15, int(irc_cfg.get("interval_seconds", 60)))

    initial_channels = _initial_irc_channels(config, project_channel)
    sys.stderr.write(
        f"orchestrator_poll[daemon]: starting nick={nick} server={server}:{port} "
        f"channels={initial_channels} interval={interval}s\n"
    )

    irc = IrcClient(server=server, port=port, nick=nick, default_channels=initial_channels)
    irc.connect()
    sys.stderr.write("orchestrator_poll[daemon]: connected\n")

    stop_flag = {"stop": False}

    def _handle_signal(signum, frame):  # noqa: ARG001
        sys.stderr.write(f"orchestrator_poll[daemon]: signal {signum}, shutting down\n")
        stop_flag["stop"] = True

    signal.signal(signal.SIGTERM, _handle_signal)
    signal.signal(signal.SIGINT, _handle_signal)

    tick_args = argparse.Namespace(seed=False, dry_run=False)

    while not stop_flag["stop"]:
        tick_started = time.time()
        try:
            config = load_config()
        except Exception as e:
            sys.stderr.write(f"orchestrator_poll[daemon]: config load failed: {e}\n")

        desired = set(_initial_irc_channels(config, project_channel))
        try:
            for ch in list(irc._joined):
                if ch not in desired:
                    irc.part(ch)
            for ch in desired:
                irc.join(ch)
        except ConnectionError:
            sys.stderr.write("orchestrator_poll[daemon]: connection lost during channel reconcile, reconnecting\n")
            try:
                irc.reconnect()
            except Exception as e:
                sys.stderr.write(f"orchestrator_poll[daemon]: reconnect failed: {e}; backing off\n")
                time.sleep(5)
                continue

        try:
            events = _run_one_tick_collect(tick_args, config)
        except Exception as e:
            sys.stderr.write(f"orchestrator_poll[daemon]: tick failed: {e}\n{traceback.format_exc()}\n")
            try:
                irc.privmsg(project_channel, f"[dispatcher_error] {e}")
            except ConnectionError:
                try:
                    irc.reconnect()
                except Exception as re:
                    sys.stderr.write(f"orchestrator_poll[daemon]: reconnect after error failed: {re}\n")
            events = []

        if events:
            try:
                dispatch_events_irc(events, irc, project_channel)
                sys.stderr.write(
                    f"orchestrator_poll[daemon]: tick dispatched {len(events)} event(s) in "
                    f"{time.time() - tick_started:.1f}s\n"
                )
            except ConnectionError as e:
                sys.stderr.write(f"orchestrator_poll[daemon]: dispatch lost connection: {e}; reconnecting\n")
                try:
                    irc.reconnect()
                except Exception as re:
                    sys.stderr.write(f"orchestrator_poll[daemon]: reconnect failed: {re}\n")
            except Exception as e:
                sys.stderr.write(f"orchestrator_poll[daemon]: dispatch error: {e}\n{traceback.format_exc()}\n")
                try:
                    irc.privmsg(project_channel, f"[dispatcher_error] dispatch: {e}")
                except Exception:
                    pass
        else:
            sys.stderr.write(
                f"orchestrator_poll[daemon]: tick clean, 0 events in {time.time() - tick_started:.1f}s\n"
            )

        slept = 0.0
        while slept < interval and not stop_flag["stop"]:
            try:
                irc.pump(timeout=1.0)
            except ConnectionError as e:
                sys.stderr.write(f"orchestrator_poll[daemon]: pump connection lost: {e}; reconnecting\n")
                try:
                    irc.reconnect()
                except Exception as re:
                    sys.stderr.write(f"orchestrator_poll[daemon]: reconnect failed: {re}\n")
                    time.sleep(5)
            slept += 1.0

    irc.close()
    sys.stderr.write("orchestrator_poll[daemon]: exited cleanly\n")
    return 0


# ---------------------------------------------------------------------------
# One-shot IRC dispatch
# ---------------------------------------------------------------------------

def _run_one_shot_dispatch_irc(args: argparse.Namespace) -> int:
    config = load_config()
    irc_cfg = config.get("irc") or {}
    nick = irc_cfg.get("nick")
    if not nick:
        raise RuntimeError("--dispatch-irc requires `irc.nick` in config")
    project_channel = irc_cfg.get("project_channel") or "#general"
    server = irc_cfg.get("server", "127.0.0.1")
    port = int(irc_cfg.get("port", 6667))
    initial_channels = _initial_irc_channels(config, project_channel)

    irc = IrcClient(server=server, port=port, nick=nick, default_channels=initial_channels)
    irc.connect()
    try:
        events = _run_one_tick_collect(args, config)
        if events:
            dispatch_events_irc(events, irc, project_channel)
            sys.stderr.write(f"orchestrator_poll[--dispatch-irc]: dispatched {len(events)} event(s)\n")
        else:
            sys.stderr.write("orchestrator_poll[--dispatch-irc]: no events to dispatch\n")
    finally:
        irc.close()
    return 0


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def _run(args: argparse.Namespace) -> int:
    config = load_config()
    events = _run_one_tick_collect(args, config)
    print(json.dumps(events, indent=2))
    return 0


def _run_self_test() -> int:
    failures: list[str] = []
    total = 0

    def check(name: str, got: object, want: object) -> None:
        nonlocal total
        total += 1
        if got != want:
            failures.append(f"FAIL {name}: got {got!r}, want {want!r}")

    # _event_channels: no linked issues → PR's own channel
    check("pr_no_linked",
          _event_channels({"pr": 25}, "#proj"),
          ["#issue-25"])

    # _event_channels: linked issues → linked issue channels, not PR channel
    check("pr_with_linked",
          _event_channels({"pr": 25, "linked_issues": [14, 7]}, "#proj"),
          ["#issue-14", "#issue-7"])

    # _event_channels: issue event
    check("issue_event",
          _event_channels({"issue": 14}, "#proj"),
          ["#issue-14"])

    # _event_channels: unrelated event falls back to default
    check("fallback",
          _event_channels({"kind": "dispatcher_error"}, "#proj"),
          ["#proj"])

    # _event_channels: de-dup is handled by dispatch caller; single linked issue
    check("pr_single_linked",
          _event_channels({"pr": 99, "linked_issues": [3]}, "#proj"),
          ["#issue-3"])

    # _initial_irc_channels: picks up linked issues from state
    fake_state = {
        "schema_version": SCHEMA_VERSION,
        "generated_at": "2026-01-01T00:00:00+00:00",
        "prs": {
            "MyOrg/repo#25": {
                "repo": "MyOrg/repo", "number": 25,
                "linked_issues": [14, 7],
            }
        },
        "issues": {},
    }
    import unittest.mock as mock
    with mock.patch(f"{__name__}.load_state", return_value=fake_state):
        chans = _initial_irc_channels(
            {"repo": "MyOrg/repo", "watched_prs": [25], "watched_issues": []},
            "#proj",
        )
    check("initial_channels_linked",
          chans,
          sorted({"#proj", "#issue-25", "#issue-14", "#issue-7"}))

    # _initial_irc_channels: no state → just config channels
    with mock.patch(f"{__name__}.load_state", return_value=None):
        chans2 = _initial_irc_channels(
            {"repo": "MyOrg/repo", "watched_prs": [25], "watched_issues": [14]},
            "#proj",
        )
    check("initial_channels_no_state",
          chans2,
          sorted({"#proj", "#issue-25", "#issue-14"}))

    check("review_comment_short",
          format_event({
              "kind": "pr_review_comment",
              "repo": "org/repo", "pr": 46, "url": "https://github.com/org/repo/pull/46",
              "author": "alice",
              "body_preview": "Looks good",
              "comment_url": "https://github.com/org/repo/pull/46#issuecomment-111",
          }),
          "PR org/repo#46 comment by alice: Looks good — https://github.com/org/repo/pull/46#issuecomment-111")

    long_body = "A" * 161
    check("review_comment_truncated",
          format_event({
              "kind": "pr_review_comment",
              "repo": "org/repo", "pr": 46, "url": "https://github.com/org/repo/pull/46",
              "author": "alice",
              "body_preview": long_body,
              "comment_url": "https://github.com/org/repo/pull/46#issuecomment-222",
          }),
          f"PR org/repo#46 comment by alice: {'A' * 160}… — https://github.com/org/repo/pull/46#issuecomment-222")

    check("review_comment_multiline",
          format_event({
              "kind": "pr_review_comment",
              "repo": "org/repo", "pr": 46, "url": "https://github.com/org/repo/pull/46",
              "author": "alice",
              "path": "src/foo.ts", "line": 10,
              "body_preview": "Line one\nLine two",
              "comment_url": "https://github.com/org/repo/pull/46#pullrequestreview-333",
          }),
          "PR org/repo#46 comment by alice at src/foo.ts:10: Line one… — https://github.com/org/repo/pull/46#pullrequestreview-333")

    check("conv_comment_short",
          format_event({
              "kind": "pr_conversation_comment",
              "repo": "org/repo", "pr": 46, "url": "https://github.com/org/repo/pull/46",
              "author": "bob",
              "body_preview": "Short comment",
              "comment_url": "https://github.com/org/repo/pull/46#issuecomment-444",
          }),
          "PR org/repo#46 comment by bob: Short comment — https://github.com/org/repo/pull/46#issuecomment-444")

    check("issue_comment_short",
          format_event({
              "kind": "issue_comment",
              "repo": "org/repo", "issue": 47, "url": "https://github.com/org/repo/issues/47",
              "author": "carol",
              "body_preview": "Hi there",
              "comment_url": "https://github.com/org/repo/issues/47#issuecomment-555",
          }),
          "Issue org/repo#47 comment by carol: Hi there — https://github.com/org/repo/issues/47#issuecomment-555")

    check("issue_comment_multiline",
          format_event({
              "kind": "issue_comment",
              "repo": "org/repo", "issue": 47, "url": "https://github.com/org/repo/issues/47",
              "author": "carol",
              "body_preview": "First line\nSecond line",
              "comment_url": "https://github.com/org/repo/issues/47#issuecomment-666",
          }),
          "Issue org/repo#47 comment by carol: First line… — https://github.com/org/repo/issues/47#issuecomment-666")

    # _format_comment_header
    check("header_pr_review_comment",
          _format_comment_header({
              "kind": "pr_review_comment", "repo": "org/repo", "pr": 46, "author": "alice",
          }),
          "PR org/repo#46 comment by alice:")

    check("header_pr_review_comment_path",
          _format_comment_header({
              "kind": "pr_review_comment", "repo": "org/repo", "pr": 46,
              "author": "alice", "path": "src/foo.ts", "line": 10,
          }),
          "PR org/repo#46 comment by alice at src/foo.ts:10:")

    check("header_issue_comment",
          _format_comment_header({
              "kind": "issue_comment", "repo": "org/repo", "issue": 47, "author": "carol",
          }),
          "Issue org/repo#47 comment by carol:")

    check("header_pr_review_submitted",
          _format_comment_header({
              "kind": "pr_review_submitted", "repo": "org/repo", "pr": 46,
              "author": "dave", "state": "APPROVED",
          }),
          "PR org/repo#46 review by dave (APPROVED):")

    # _multiline_split_line
    check("split_short", _multiline_split_line("hello"), ["hello"])

    long_line = "A" * (MULTILINE_LINE_BYTES + 10)
    split_result = _multiline_split_line(long_line)
    check("split_long_count", len(split_result) > 1, True)
    check("split_long_reassemble", "".join(split_result), long_line)

    # format_comment_event includes full body field
    test_c = {"id": 1, "html_url": "https://example.com/c/1",
              "user": {"login": "alice"}, "body": "Line one\nLine two"}
    ev_body = format_comment_event(test_c, kind="issue_comment", repo="org/repo",
                                   pr=None, issue=47, url="https://example.com/i/47")
    check("event_full_body", ev_body.get("body"), "Line one\nLine two")
    check("event_body_preview", ev_body.get("body_preview"), "Line one\nLine two")

    # comment_privmsg: multiline path
    _cl = IrcClient("127.0.0.1", 6667, "test-nick")
    _cl._multiline_enabled = True
    _cl._multiline_max_bytes = 16384
    _cl._multiline_max_lines = 200
    _cl._joined = {"#test"}
    _sent_ml: list[str] = []
    _cl._send_raw = _sent_ml.append  # type: ignore[method-assign]
    _cl.pump = lambda timeout=0.0: None  # type: ignore[method-assign]
    _cl.comment_privmsg("#test", "Header:", "Body line 1\n\nBody line 3",
                        "https://example.com", "fallback")
    check("ml_batch_start", any("BATCH +" in l and "draft/multiline" in l for l in _sent_ml), True)
    check("ml_batch_end", any("BATCH -" in l for l in _sent_ml), True)
    check("ml_has_header", any(":Header:" in l for l in _sent_ml), True)
    check("ml_has_url", any("https://example.com" in l for l in _sent_ml), True)
    check("ml_no_fallback", not any("fallback" in l for l in _sent_ml), True)

    # comment_privmsg: fallback when not enabled
    _cl2 = IrcClient("127.0.0.1", 6667, "test-nick2")
    _cl2._multiline_enabled = False
    _cl2._joined = {"#test"}
    _sent_fb: list[str] = []
    _cl2._send_raw = _sent_fb.append  # type: ignore[method-assign]
    _cl2.pump = lambda timeout=0.0: None  # type: ignore[method-assign]
    _cl2.comment_privmsg("#test", "Header:", "Body", "https://example.com", "fallback text")
    check("fb_has_fallback", any("fallback text" in l for l in _sent_fb), True)
    check("fb_no_batch", not any("BATCH" in l for l in _sent_fb), True)

    # comment_privmsg: fallback when body exceeds server limits
    _cl3 = IrcClient("127.0.0.1", 6667, "test-nick3")
    _cl3._multiline_enabled = True
    _cl3._multiline_max_bytes = 10
    _cl3._multiline_max_lines = 200
    _cl3._joined = {"#test"}
    _sent_ov: list[str] = []
    _cl3._send_raw = _sent_ov.append  # type: ignore[method-assign]
    _cl3.pump = lambda timeout=0.0: None  # type: ignore[method-assign]
    _cl3.comment_privmsg("#test", "Header:", "Body exceeds tiny byte limit",
                         "https://example.com", "fallback oversized")
    check("ov_has_fallback", any("fallback oversized" in l for l in _sent_ov), True)
    check("ov_no_batch", not any("BATCH" in l for l in _sent_ov), True)

    if failures:
        for f in failures:
            sys.stderr.write(f + "\n")
        return 1
    sys.stdout.write(f"self-test: {total}/{total} passed\n")
    return 0


def _record_error() -> None:
    tb = traceback.format_exc()
    try:
        STATE_DIR.mkdir(exist_ok=True)
        LAST_ERROR_PATH.write_text(tb)
    except Exception:
        pass


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--seed", action="store_true", help="Force re-seed; emit [].")
    ap.add_argument("--dry-run", action="store_true", help="Do not persist state or heartbeat.")
    ap.add_argument("--dispatch-irc", action="store_true",
                    help="One-shot: PRIVMSG qualifying events to per-issue IRC channels.")
    ap.add_argument("--daemon", action="store_true",
                    help="Long-running: persistent IRC connection, poll → dispatch → sleep loop.")
    ap.add_argument("--self-test", action="store_true",
                    help="Run pure-function routing self-tests against fixture data.")
    ap.add_argument("--config-dir", default=None,
                    help="Override state directory (default: <repo>/.orchestrator).")
    args = ap.parse_args()

    if args.config_dir:
        global STATE_DIR, CONFIG_PATH, STATE_PATH, HEARTBEAT_PATH, LAST_ERROR_PATH
        STATE_DIR = pathlib.Path(args.config_dir).resolve()
        CONFIG_PATH = STATE_DIR / "config.json"
        STATE_PATH = STATE_DIR / "state.json"
        HEARTBEAT_PATH = STATE_DIR / "last-tick.txt"
        LAST_ERROR_PATH = STATE_DIR / "last-error.txt"

    try:
        if getattr(args, "self_test", False):
            return _run_self_test()
        if args.daemon:
            return _run_daemon(args)
        if args.dispatch_irc:
            return _run_one_shot_dispatch_irc(args)
        return _run(args)
    except Exception:
        sys.stderr.write(traceback.format_exc())
        _record_error()
        return 3


if __name__ == "__main__":
    raise SystemExit(main())
