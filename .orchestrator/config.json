{
  "project": "roost",
  "repo": "AvesAlight/roost",
  "agent_logins": ["TeakBuilds"],
  "irc": {
    "nick": "roost-dispatcher",
    "project_channel": "#roost-leads",
    "server": "127.0.0.1",
    "port": 6667,
    "interval_seconds": 30
  },
  "plugins": {
    "github-new-issues": { "watched": [{ "repo": "AvesAlight/roost" }] },
    "github-commits": {
      "watched": [
        {
          "repo": "AvesAlight/homebrew-tap",
          "branch": "main",
          "path": "Formula/roost.rb",
          "channels": ["#roost-leads"]
        }
      ]
    }
  }
}
